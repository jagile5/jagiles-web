---
// Short about teaser for homepage
---

<section class="relative py-28" data-animate>
  <div class="grain-overlay" />
  <div class="relative z-10 max-w-xl mx-auto px-6 text-center">
    <p class="eyebrow mb-4">A bit about me</p>
    <p class="text-text/85 text-lg md:text-xl leading-relaxed font-sans">
      Videographer and drone operator based in North Vancouver, BC, originally from New Zealand.
      When I'm not on a shoot I'm probably flying FPV drones, riding a OneWheel I built myself,
      or deep in some homelab project.
    </p>
    <a href="/about" class="inline-block mt-8 text-primary font-display font-semibold text-lg
                            transition-all duration-300 hover:text-secondary">
      More about me &rarr;
    </a>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('astro:page-load', () => {
    gsap.from('[data-animate]', {
      scrollTrigger: {
        trigger: '[data-animate]',
        start: 'top 80%',
      },
      opacity: 0,
      y: 40,
      duration: 0.8,
      ease: 'power3.out',
    });
  });
</script>