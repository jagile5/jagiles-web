---
interface Props {
  items: string[];
  speed?: number;
  reverse?: boolean;
}

const { items, speed = 30, reverse = false } = Astro.props;
const tripled = [...items, ...items, ...items];
---

<div class="marquee-track relative" data-speed={speed} data-reverse={reverse ? '1' : ''} data-items={tripled.join('||')}>
  <canvas class="marquee-canvas" aria-hidden="true"></canvas>
  <div class="marquee-inner sr-only" aria-hidden="true">
    {tripled.map((item, i) => (
      <span class="marquee-item">{item}</span>
    ))}
  </div>
  <span class="sr-only">{tripled.filter((_, i) => i < items.length).join(', ')}</span>
</div>

<script>
function initMarqueeEffects() {
  const tracks = document.querySelectorAll('.marquee-track');

  tracks.forEach(function (track) {
    const canvas = track.querySelector('.marquee-canvas');
    if (!canvas) return;
    const ctx = (canvas as HTMLCanvasElement).getContext('2d');
    if (!ctx) return;

    const baseSpeed = parseFloat((track as HTMLElement).dataset.speed || '30');
    const isReverse = (track as HTMLElement).dataset.reverse === '1';
    const rawItems = ((track as HTMLElement).dataset.items || '').split('||').map(function (s) {
      return s.replace(/\b\w/g, function (c) { return c.toUpperCase(); });
    });

    // --- 2D Water Simulation ---
    const Q = 4;
    let ww = 0, wh = 0, wSize = 0;
    let buf1: Int16Array, buf2: Int16Array;
    const DAMP = 0.985;

    function initBuffers(w: number, h: number) {
      ww = Math.ceil(w / Q);
      wh = Math.ceil(h / Q);
      const newSize = ww * wh;
      if (wSize !== newSize) {
        wSize = newSize;
        buf1 = new Int16Array(wSize);
        buf2 = new Int16Array(wSize);
      }
    }

    function dropAt(px: number, py: number, dx: number, dy: number, speed: number) {
      const cx = (px / Q) | 0;
      const cy = (py / Q) | 0;
      const r = Math.max(6, (speed * 0.4 / Q + 6) | 0);
      const strength = Math.min(speed * 5, 100);
      const len = Math.sqrt(dx * dx + dy * dy) || 1;
      const nx = dx / len;
      const ny = dy / len;

      for (var oy = -r; oy <= r; oy++) {
        for (var ox = -r; ox <= r; ox++) {
          var dist2 = ox * ox + oy * oy;
          if (dist2 <= r * r) {
            var idx = (cy + oy) * ww + (cx + ox);
            if (idx > 0 && idx < wSize) {
              var dot = (ox * nx + oy * ny);
              var dist = Math.sqrt(dist2);
              var edgeFade = 1 - (dist / r);
              buf1[idx] += (strength * (0.3 + dot * 0.7) * edgeFade * edgeFade) | 0;
            }
          }
        }
      }
    }

    function stepWater() {
      for (var sy = 1; sy < wh - 1; sy++) {
        for (var sx = 1; sx < ww - 1; sx++) {
          var i = sy * ww + sx;
          buf2[i] = ((buf1[i - 1] + buf1[i + 1] + buf1[i - ww] + buf1[i + ww]) >> 1) - buf2[i];
          buf2[i] = (buf2[i] * DAMP) | 0;
        }
      }
      for (var ex = 0; ex < ww; ex++) {
        buf2[ex] = 0;
        buf2[(wh - 1) * ww + ex] = 0;
      }
      for (var ey = 0; ey < wh; ey++) {
        buf2[ey * ww] = 0;
        buf2[ey * ww + ww - 1] = 0;
      }
      var tmp = buf1; buf1 = buf2; buf2 = tmp;
    }

    // --- Texture canvas ---
    const texCanvas = document.createElement('canvas');
    const tCtx = texCanvas.getContext('2d')!;

    const FONT = '600 14px/1 "Space Grotesk", sans-serif';
    const SEP = '✦';
    const HALF_GAP = 28;
    let itemInfo: { text: string; width: number }[] = [];
    let sepW = 0;
    let repeatW = 0;

    function measure() {
      tCtx.font = FONT;
      itemInfo = rawItems.map(function (t) { return { text: t, width: tCtx.measureText(t).width }; });
      sepW = tCtx.measureText(SEP).width;
      repeatW = 0;
      for (var mi = 0; mi < itemInfo.length; mi++) {
        repeatW += HALF_GAP + itemInfo[mi].width + HALF_GAP + sepW;
      }
      repeatW += HALF_GAP;
    }

    function renderTexture(w: number, h: number, scrollOff: number) {
      texCanvas.width = w;
      texCanvas.height = h;
      tCtx.fillStyle = '#262626';
      tCtx.fillRect(0, 0, w, h);
      tCtx.strokeStyle = 'rgba(20, 155, 155, 0.35)';
      tCtx.lineWidth = 1;
      tCtx.beginPath(); tCtx.moveTo(0, 0.5); tCtx.lineTo(w, 0.5); tCtx.stroke();
      tCtx.beginPath(); tCtx.moveTo(0, h - 0.5); tCtx.lineTo(w, h - 0.5); tCtx.stroke();

      if (repeatW <= 0) return tCtx.getImageData(0, 0, w, h).data;

      tCtx.font = FONT;
      tCtx.textBaseline = 'middle';
      var centerY = h / 2;
      var offset = ((scrollOff % repeatW) + repeatW) % repeatW;

      for (var rep = -1; rep <= 2; rep++) {
        var curX = rep * repeatW - offset;
        for (var ii = 0; ii < itemInfo.length; ii++) {
          var item = itemInfo[ii];
          var textX = curX + HALF_GAP;
          if (textX + item.width / 2 > -300 && textX + item.width / 2 < w + 300) {
            tCtx.fillStyle = 'rgba(247, 247, 247, 0.85)';
            tCtx.fillText(item.text, textX, centerY);
          }
          var sepX = textX + item.width + HALF_GAP;
          tCtx.fillStyle = 'rgba(20, 155, 155, 0.7)';
          tCtx.fillText(SEP, sepX, centerY);
          curX += HALF_GAP + item.width + HALF_GAP + sepW;
        }
      }

      return tCtx.getImageData(0, 0, w, h).data;
    }

    // --- State ---
    let animFrameId: number;
    let lastMx = -1, lastMy = -1;
    let scrollOffset = 0;
    let lastTime = 0;
    let curW = 0, curH = 0;
    let outputImg: ImageData;

    function resizeCanvas() {
      const rect = track.getBoundingClientRect();
      curW = rect.width | 0;
      curH = rect.height | 0;
      (canvas as HTMLCanvasElement).width = curW;
      (canvas as HTMLCanvasElement).height = curH;
      (canvas as HTMLCanvasElement).style.width = curW + 'px';
      (canvas as HTMLCanvasElement).style.height = curH + 'px';
      initBuffers(curW, curH);
      measure();
      outputImg = ctx.createImageData(curW, curH);
    }
    resizeCanvas();
    new ResizeObserver(resizeCanvas).observe(track);

    track.addEventListener('mouseleave', function () { lastMx = -1; lastMy = -1; });

    track.addEventListener('mousemove', function (e) {
      const rect = track.getBoundingClientRect();
      const mx = e.clientX - rect.left;
      const my = e.clientY - rect.top;
      if (lastMx >= 0) {
        const dx = mx - lastMx;
        const dy = my - lastMy;
        const speed = Math.sqrt(dx * dx + dy * dy);
        if (speed > 1) dropAt(mx, my, dx, dy, speed);
      }
      lastMx = mx;
      lastMy = my;
    });

    // --- Render loop ---
    function draw(time: number) {
      if (!lastTime) lastTime = time;
      const dt = Math.min((time - lastTime) / 1000, 0.05);
      lastTime = time;
      const w = curW;
      const h = curH;
      if (w <= 0 || h <= 0) { animFrameId = requestAnimationFrame(draw); return; }

      scrollOffset += (repeatW / baseSpeed) * dt * (isReverse ? -1 : 1);
      stepWater();

      const tex = renderTexture(w, h, scrollOffset);
      const out = outputImg.data;

      for (var py = 0; py < h; py++) {
        for (var px = 0; px < w; px++) {
          var gx = (px / Q) | 0;
          var gy = (py / Q) | 0;
          var pi = (py * w + px) * 4;

          if (gx > 0 && gx < ww - 1 && gy > 0 && gy < wh - 1) {
            var gi = gy * ww + gx;
            var offX = (buf1[gi - 1] - buf1[gi + 1]) >> 2;
            var offY = (buf1[gi - ww] - buf1[gi + ww]) >> 2;
            var sxs = px + offX;
            var sys = py + offY;
            sxs = sxs < 0 ? 0 : sxs >= w ? w - 1 : sxs;
            sys = sys < 0 ? 0 : sys >= h ? h - 1 : sys;
            var si = (sys * w + sxs) * 4;
            var boost = Math.abs(buf1[gi]) >> 4;
            out[pi] = Math.min(255, tex[si] + boost);
            out[pi + 1] = Math.min(255, tex[si + 1] + boost);
            out[pi + 2] = Math.min(255, tex[si + 2] + boost);
            out[pi + 3] = tex[si + 3];
          } else {
            out[pi] = tex[pi];
            out[pi + 1] = tex[pi + 1];
            out[pi + 2] = tex[pi + 2];
            out[pi + 3] = tex[pi + 3];
          }
        }
      }

      ctx.putImageData(outputImg, 0, 0);
      animFrameId = requestAnimationFrame(draw);
    }

    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            lastTime = 0;
            animFrameId = requestAnimationFrame(draw);
          } else {
            cancelAnimationFrame(animFrameId);
          }
        });
      },
      { threshold: 0 }
    );
    observer.observe(track);
  });
}

initMarqueeEffects();
document.addEventListener('astro:page-load', initMarqueeEffects);
</script>

<style>
.marquee-track {
  position: relative;
  height: 52px;
}

.marquee-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.marquee-reverse {
  animation-direction: reverse;
}

@media (prefers-reduced-motion: reduce) {
  .marquee-track {
    height: auto;
  }
  .marquee-canvas {
    display: none;
  }
  .marquee-inner {
    position: static;
    clip: auto;
    width: auto;
    height: auto;
  }
  .marquee-item {
    display: inline;
  }
}
</style>
