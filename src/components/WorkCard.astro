---
export interface Props {
  videoUrl: string;
  title: string;
  client: string;
  category: string[];
  year: number;
  slug: string;
}

const { videoUrl, title, client, category, year, slug } = Astro.props;
const isYouTube = videoUrl.includes('youtube.com/embed') || videoUrl.includes('youtu.be');
const isInstagram = videoUrl.includes('instagram.com');

// Extract YouTube video ID from embed URL
const youtubeMatch = videoUrl.match(/\/embed\/([a-zA-Z0-9_-]+)/);
const youtubeId = youtubeMatch ? youtubeMatch[1] : null;
const thumbnailUrl = youtubeId ? `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg` : null;
---

{isInstagram ? (
  <a
    href={videoUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="work-card block relative"
    data-categories={category.join(' ')}
  >
    <div class="relative aspect-video overflow-hidden rounded-xl bg-surface">
      <div class="flex h-full w-full items-center justify-center bg-gray-800 text-gray-400">
        Instagram Post
      </div>
    </div>
    <div class="mt-3">
      <h3 class="font-display text-base font-semibold leading-snug text-text/90">
        {title}
      </h3>
      <p class="mt-0.5 text-xs tracking-wide uppercase text-text/50">{client}</p>
    </div>
  </a>
) : (
  <a
    href={`/work/${slug}`}
    class="work-card block relative"
    data-categories={category.join(' ')}
  >
    <div class="relative aspect-video overflow-hidden rounded-xl bg-surface">
      {isYouTube && youtubeId ? (
        <div
          class="relative w-full h-full"
          data-yt-card={youtubeId}
          data-yt-title={title}
        >
          <img
            src={thumbnailUrl}
            alt={title}
            class="w-full h-full object-cover"
            loading="lazy"
            data-yt-thumb
            onerror={`this.onerror=null;this.src='https://img.youtube.com/vi/${youtubeId}/hqdefault.jpg'`}
          />
        </div>
      ) : (
        <video
          src={videoUrl}
          muted
          loop
          playsinline
          preload="metadata"
          class="w-full h-full object-cover"
          loading="lazy"
        ></video>
      )}
    </div>
    <div class="mt-3">
      <h3 class="font-display text-base font-semibold leading-snug text-text/90">
        {title}
      </h3>
      <p class="mt-0.5 text-xs tracking-wide uppercase text-text/50">{client}</p>
    </div>
  </a>
)}

<style>
  .work-card::before {
    content: '';
    position: absolute;
    inset: -36px -24px;
    border-radius: 2.25rem;
    background:
      /* Horizontal scanlines */
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(0, 0, 0, 0.25) 3px,
        rgba(0, 0, 0, 0.25) 5px
      ),
      /* Vertical pixel bars */
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 3px,
        rgba(0, 0, 0, 0.14) 3px,
        rgba(0, 0, 0, 0.14) 5px
      ),
      /* Dark CRT glow */
      rgba(15, 30, 50, 0.8);
    opacity: 0.15;
    z-index: -1;
    pointer-events: none;
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      black 20%,
      rgba(0, 0, 0, 0.7) 40%,
      rgba(0, 0, 0, 0.25) 60%,
      transparent 80%
    );
    mask-image: radial-gradient(
      ellipse at center,
      black 20%,
      rgba(0, 0, 0, 0.7) 40%,
      rgba(0, 0, 0, 0.25) 60%,
      transparent 80%
    );
  }
</style>