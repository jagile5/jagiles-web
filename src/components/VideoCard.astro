---
export interface Props {
  videoUrl: string;
  title: string;
  client: string;
  category: string[];
  year: number;
  slug: string;
}

const { videoUrl, title, client, category, year, slug } = Astro.props;
---

<a
  href={`/work/${slug}`}
  class="work-card group block cursor-pointer relative hover:scale-[1.25] hover:z-10"
  style="transition: transform 500ms ease-out, filter 500ms ease-out, opacity 500ms ease-out, box-shadow 500ms ease-out;"
  data-categories={category.join(' ')}
>
  <div class="relative aspect-video overflow-hidden rounded-xl bg-surface">
    <video
      src={videoUrl}
      muted
      loop
      playsinline
      preload="metadata"
      class="w-full h-full object-cover saturate-0 transition-all duration-700 group-hover:saturate-100"
      loading="lazy"
    ></video>
  </div>
  <div class="mt-3">
    <h3 class="font-display text-base font-semibold leading-snug group-hover:text-primary transition-colors duration-300">
      {title}
    </h3>
    <p class="mt-0.5 text-xs tracking-wide uppercase text-text/50">{client}</p>
  </div>
</a>

<style>
  .work-card::before {
    content: '';
    position: absolute;
    inset: -36px -24px;
    border-radius: 2.25rem;
    background:
      /* Horizontal scanlines */
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(0, 0, 0, 0.25) 3px,
        rgba(0, 0, 0, 0.25) 5px
      ),
      /* Vertical pixel bars */
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 3px,
        rgba(0, 0, 0, 0.14) 3px,
        rgba(0, 0, 0, 0.14) 5px
      ),
      /* Dark CRT glow */
      rgba(15, 30, 50, 0.8);
    opacity: 0;
    transition: opacity 500ms ease-out;
    z-index: -1;
    pointer-events: none;
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      black 20%,
      rgba(0, 0, 0, 0.7) 40%,
      rgba(0, 0, 0, 0.25) 60%,
      transparent 80%
    );
    mask-image: radial-gradient(
      ellipse at center,
      black 20%,
      rgba(0, 0, 0, 0.7) 40%,
      rgba(0, 0, 0, 0.25) 60%,
      transparent 80%
    );
  }

  .work-card:hover::before {
    opacity: 1;
  }
</style>
