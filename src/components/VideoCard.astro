---
export interface Props {
  videoUrl: string;
  title: string;
  client: string;
  category: string[];
  year: number;
  slug: string;
}

const { videoUrl, title, client, category, year, slug } = Astro.props;
const isYouTube = videoUrl.includes('youtube.com/embed') || videoUrl.includes('youtu.be');
const isInstagram = videoUrl.includes('instagram.com');

// Extract YouTube video ID from embed URL
const youtubeMatch = videoUrl.match(/\/embed\/([a-zA-Z0-9_-]+)/);
const youtubeId = youtubeMatch ? youtubeMatch[1] : null;
const thumbnailUrl = youtubeId ? `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg` : null;
---

{isInstagram ? (
  <a
    href={videoUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="work-card group block cursor-pointer relative hover:scale-[1.25] hover:z-10"
    style="transition: transform 500ms ease-out, filter 500ms ease-out, opacity 500ms ease-out, box-shadow 500ms ease-out;"
    data-categories={category.join(' ')}
  >
    <div class="relative aspect-video overflow-hidden rounded-xl bg-surface">
      <div class="flex h-full w-full items-center justify-center bg-gray-800 text-gray-400">
        Instagram Post
      </div>
    </div>
    <div class="mt-3">
      <h3 class="font-display text-base font-semibold leading-snug group-hover:text-primary transition-colors duration-300">
        {title}
      </h3>
      <p class="mt-0.5 text-xs tracking-wide uppercase text-text/50">{client}</p>
    </div>
  </a>
) : (
  <a
    href={`/work/${slug}`}
    class="work-card group block cursor-pointer relative hover:scale-[1.25] hover:z-10"
    style="transition: transform 500ms ease-out, filter 500ms ease-out, opacity 500ms ease-out, box-shadow 500ms ease-out;"
    data-categories={category.join(' ')}
  >
    <div class="relative aspect-video overflow-hidden rounded-xl bg-surface">
      {isYouTube && youtubeId ? (
        <div
          class="relative w-full h-full"
          data-yt-card={youtubeId}
          data-yt-title={title}
        >
          <img
            src={thumbnailUrl}
            alt={title}
            class="w-full h-full object-cover"
            loading="lazy"
            data-yt-thumb
            onerror={`this.onerror=null;this.src='https://img.youtube.com/vi/${youtubeId}/hqdefault.jpg'`}
          />
        </div>
      ) : (
        <video
          src={videoUrl}
          muted
          loop
          playsinline
          preload="metadata"
          class="w-full h-full object-cover saturate-0 transition-all duration-700 group-hover:saturate-100"
          loading="lazy"
        ></video>
      )}
    </div>
    <div class="mt-3">
      <h3 class="font-display text-base font-semibold leading-snug group-hover:text-primary transition-colors duration-300">
        {title}
      </h3>
      <p class="mt-0.5 text-xs tracking-wide uppercase text-text/50">{client}</p>
    </div>
  </a>
)}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('[data-yt-card]');

    cards.forEach((container) => {
      const videoId = container.getAttribute('data-yt-card');
      const videoTitle = container.getAttribute('data-yt-title') || 'Project video';
      if (!videoId) return;

      let iframe = null;
      let thumbnail = container.querySelector('[data-yt-thumb]');
      let fadeTimeout = null;

      container.addEventListener('mouseenter', () => {
        // Remove any pending leave-timeout
        if (fadeTimeout) { clearTimeout(fadeTimeout); fadeTimeout = null; }
        // Create iframe immediately but hidden
        if (!iframe) {
          iframe = document.createElement('iframe');
          iframe.setAttribute('src', `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&controls=0&loop=1&playlist=${videoId}&modestbranding=1&rel=0&showinfo=0&iv_load_policy=3&disablekb=1&fs=0&playsinline=1`);
          iframe.setAttribute('title', videoTitle);
          iframe.setAttribute('frameborder', '0');
          iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
          iframe.setAttribute('allowfullscreen', '');
          iframe.className = 'w-full h-full absolute inset-0';
          iframe.style.opacity = '0';
          iframe.style.transition = 'opacity 250ms ease-out';
          iframe.style.pointerEvents = 'none';
          container.appendChild(iframe);
        }
        // Keep thumbnail visible while iframe loads, then fade it out
        fadeTimeout = setTimeout(() => {
          if (thumbnail) {
            thumbnail.remove();
            thumbnail = null;
          }
          if (iframe) {
            iframe.style.opacity = '1';
            iframe.style.pointerEvents = 'auto';
          }
          fadeTimeout = null;
        }, 450);
      });

      container.addEventListener('mouseleave', () => {
        // Cancel any pending fade-in if user left quickly
        if (fadeTimeout) { clearTimeout(fadeTimeout); fadeTimeout = null; }
        // Remove iframe entirely so playback stops and bandwidth is freed
        if (iframe && iframe.parentNode) {
          iframe.parentNode.removeChild(iframe);
          iframe = null;
        }
        // Recreate thumbnail if not present
        if (!thumbnail) {
          thumbnail = document.createElement('img');
          thumbnail.setAttribute('src', `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`);
          thumbnail.setAttribute('alt', videoTitle);
          thumbnail.setAttribute('loading', 'lazy');
          thumbnail.className = 'w-full h-full object-cover';
          thumbnail.setAttribute('data-yt-thumb', '');
          thumbnail.onerror = function() {
            this.onerror = null;
            this.src = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
          };
          container.appendChild(thumbnail);
        }
      });

      // Prefetch: preconnect to YouTube on scroll-into-view so the
      // connection handshake is already done by the time the user hovers
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          const link = document.createElement('link');
          link.rel = 'preconnect';
          link.href = 'https://www.youtube.com';
          document.head.appendChild(link);
          const imgLink = document.createElement('link');
          imgLink.rel = 'preconnect';
          imgLink.href = 'https://img.youtube.com';
          document.head.appendChild(imgLink);
          observer.disconnect();
        }
      });
      observer.observe(container);
    });
  });
</script>

<style>
  .work-card::before {
    content: '';
    position: absolute;
    inset: -36px -24px;
    border-radius: 2.25rem;
    background:
      /* Horizontal scanlines */
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(0, 0, 0, 0.25) 3px,
        rgba(0, 0, 0, 0.25) 5px
      ),
      /* Vertical pixel bars */
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 3px,
        rgba(0, 0, 0, 0.14) 3px,
        rgba(0, 0, 0, 0.14) 5px
      ),
      /* Dark CRT glow */
      rgba(15, 30, 50, 0.8);
    opacity: 0;
    transition: opacity 500ms ease-out;
    z-index: -1;
    pointer-events: none;
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      black 20%,
      rgba(0, 0, 0, 0.7) 40%,
      rgba(0, 0, 0, 0.25) 60%,
      transparent 80%
    );
    mask-image: radial-gradient(
      ellipse at center,
      black 20%,
      rgba(0, 0, 0, 0.7) 40%,
      rgba(0, 0, 0, 0.25) 60%,
      transparent 80%
    );
  }

  .work-card:hover::before {
    opacity: 1;
  }
</style>