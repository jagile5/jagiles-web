---
// Hero: 3D CRT TV drops from above, screen flickers on
---

<section id="hero" class="relative w-full h-screen overflow-hidden bg-bg">
  <canvas id="crt-canvas" class="absolute inset-0 w-full h-full"></canvas>
</section>

<script>
import * as THREE from 'three';
import { RoundedBoxGeometry } from 'three/examples/jsm/geometries/RoundedBoxGeometry.js';
import { gsap } from 'gsap';
import { EffectComposer } from 'three/examples/jsm/postprocessing/EffectComposer.js';
import { RenderPass } from 'three/examples/jsm/postprocessing/RenderPass.js';
import { UnrealBloomPass } from 'three/examples/jsm/postprocessing/UnrealBloomPass.js';

function initHero() {
  const canvas = document.getElementById('crt-canvas') as HTMLCanvasElement;
  if (!canvas) return;

  // --- Renderer ---
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setClearColor(0x080808);
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 0.85;
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;

  // --- Scene & Camera ---
  const scene = new THREE.Scene();

  const camera = new THREE.PerspectiveCamera(35, window.innerWidth / window.innerHeight, 0.1, 100);
  camera.position.set(0.2, 1.2, 12);
  camera.lookAt(0, 0.3, 0);

  // === LIGHTING — dark, cinematic, cool ===
  const hemi = new THREE.HemisphereLight(0xeeefff, 0x111122, 0.15);
  scene.add(hemi);

  // Key — soft shadows, slight cool
  const keyLight = new THREE.DirectionalLight(0xeeffff, 1.4);
  keyLight.position.set(4, 6, 5);
  keyLight.castShadow = true;
  keyLight.shadow.mapSize.width = 2048;
  keyLight.shadow.mapSize.height = 2048;
  keyLight.shadow.camera.near = 0.1;
  keyLight.shadow.camera.far = 20;
  keyLight.shadow.camera.left = -6;
  keyLight.shadow.camera.right = 6;
  keyLight.shadow.camera.top = 6;
  keyLight.shadow.camera.bottom = -6;
  keyLight.shadow.bias = -0.001;
  keyLight.shadow.radius = 15;
  scene.add(keyLight);

  // Fill
  const fillLight = new THREE.DirectionalLight(0xbbddff, 0.15);
  fillLight.position.set(-3, 2, 4);
  scene.add(fillLight);

  // Rim
  const rimLight = new THREE.DirectionalLight(0x8899cc, 0.15);
  rimLight.position.set(-2, 1, -6);
  scene.add(rimLight);

  // --- Grunge texture generator ---
  function makeGrungeTex(w: number, h: number, baseR: number, baseG: number, baseB: number, seed: number): THREE.CanvasTexture {
    const c = document.createElement('canvas');
    c.width = w; c.height = h;
    const ctx = c.getContext('2d')!;
    ctx.fillStyle = `rgb(${baseR},${baseG},${baseB})`;
    ctx.fillRect(0, 0, w, h);
    let s = seed;
    const rand = () => { s = (s * 16807 + 0) % 2147483647; return (s & 0x7fffffff) / 0x7fffffff; };
    for (let i = 0; i < 40; i++) {
      const sx = rand() * w, sy = rand() * h, sr = 20 + rand() * 80;
      const dr = -15 + rand() * -25, dg = -10 + rand() * -20, db = -5 + rand() * -15;
      ctx.fillStyle = `rgba(${Math.max(0,baseR+dr|0)},${Math.max(0,baseG+dg|0)},${Math.max(0,baseB+db|0)},${0.15+rand()*0.2})`;
      ctx.beginPath(); ctx.ellipse(sx, sy, sr, sr * (0.4+rand()*0.6), rand()*Math.PI, 0, Math.PI*2); ctx.fill();
    }
    for (let i = 0; i < 60; i++) {
      const sx = rand()*w, sy = rand()*h, len = 10+rand()*60, ang = rand()*Math.PI;
      ctx.strokeStyle = `rgba(0,0,0,${0.05+rand()*0.1})`;
      ctx.lineWidth = 0.5+rand()*1.5;
      ctx.beginPath(); ctx.moveTo(sx,sy); ctx.lineTo(sx+Math.cos(ang)*len, sy+Math.sin(ang)*len); ctx.stroke();
    }
    for (let i = 0; i < 8000; i++) {
      const nx = rand()*w, ny = rand()*h;
      const v = rand() > 0.5 ? 255 : 0;
      ctx.fillStyle = `rgba(${v},${v},${v},${0.01+rand()*0.03})`;
      ctx.fillRect(nx, ny, 1, 1);
    }
    const tex = new THREE.CanvasTexture(c);
    tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
    return tex;
  }

  // --- Materials ---
  const bodyMat = new THREE.MeshStandardMaterial({
    map: makeGrungeTex(1024, 1024, 140, 90, 45, 42),
    roughnessMap: makeGrungeTex(512, 512, 100, 100, 100, 99),
    roughness: 0.55, metalness: 0.0, color: 0x7a5530,
  });
  const darkBodyMat = new THREE.MeshStandardMaterial({
    map: makeGrungeTex(1024, 1024, 110, 70, 35, 55),
    roughness: 0.6, metalness: 0.0, color: 0x604028,
  });
  const darkPlasticMat = new THREE.MeshStandardMaterial({
    map: makeGrungeTex(512, 512, 22, 22, 22, 77),
    roughnessMap: makeGrungeTex(512, 512, 100, 100, 100, 33),
    roughness: 0.85, metalness: 0.0, color: 0x1a1a1a,
  });
  const trimMat = new THREE.MeshStandardMaterial({ color: 0x7a6e5b, roughness: 0.5, metalness: 0.3 });
  const chromeMat = new THREE.MeshStandardMaterial({ color: 0xbbbbbb, roughness: 0.18, metalness: 0.9 });
  const metalMat = new THREE.MeshStandardMaterial({ color: 0x777777, metalness: 0.8, roughness: 0.25 });
  const woodMat = new THREE.MeshStandardMaterial({ color: 0x6b5238, roughness: 0.75, metalness: 0.0 });

  // === GROUND PLANE — infinite fade with radial gradient ===
  const groundCanvas = document.createElement('canvas');
  groundCanvas.width = 512; groundCanvas.height = 512;
  const gctx = groundCanvas.getContext('2d')!;
  const grad = gctx.createRadialGradient(256, 256, 0, 256, 256, 256);
  grad.addColorStop(0, 'rgba(8,8,8,1)');
  grad.addColorStop(0.3, 'rgba(8,8,8,1)');
  grad.addColorStop(0.6, 'rgba(8,8,8,0.6)');
  grad.addColorStop(1, 'rgba(8,8,8,0)');
  gctx.fillStyle = grad;
  gctx.fillRect(0, 0, 512, 512);
  const groundTex = new THREE.CanvasTexture(groundCanvas);

  const floorMat = new THREE.MeshStandardMaterial({
    map: groundTex,
    roughness: 0.9,
    metalness: 0.0,
    transparent: true,
    depthWrite: false,
  });
  const floor = new THREE.Mesh(new THREE.PlaneGeometry(28, 28), floorMat);
  floor.rotation.x = -Math.PI / 2;
  floor.position.y = -1.15;
  floor.receiveShadow = true;
  scene.add(floor);

  // --- TV group ---
  const tvGroup = new THREE.Group();
  scene.add(tvGroup);

  const bodyW = 4.0, bodyH = 2.4, bodyD = 4.4;

  // Main shell — sharper edges, less rounded
  const body = new THREE.Mesh(new RoundedBoxGeometry(bodyW, bodyH, bodyD, 8, 0.06), bodyMat);
  body.castShadow = true;
  tvGroup.add(body);

  // CRT hump
  const hump = new THREE.Mesh(new RoundedBoxGeometry(bodyW * 0.65, bodyH * 0.5, 1.2, 5, 0.2), bodyMat);
  hump.position.set(0, -0.05, -bodyD / 2 - 0.5);
  hump.castShadow = true;
  tvGroup.add(hump);

  // Back vent panel + slats
  const ventMat = new THREE.MeshStandardMaterial({ color: 0x2a2520, roughness: 0.9 });
  const ventPanel = new THREE.Mesh(new RoundedBoxGeometry(bodyW * 0.6, bodyH * 0.45, 0.06, 4, 0.05), ventMat);
  ventPanel.position.set(0, 0.05, -bodyD / 2 - 1.1);
  tvGroup.add(ventPanel);
  const slatGeo = new THREE.BoxGeometry(bodyW * 0.5, 0.04, 0.08);
  const slatMat = new THREE.MeshStandardMaterial({ color: 0x1a1510, roughness: 0.9 });
  for (let i = 0; i < 10; i++) {
    const slat = new THREE.Mesh(slatGeo, slatMat);
    slat.position.set(0, -bodyH * 0.16 + i * 0.1, -bodyD / 2 - 1.15);
    tvGroup.add(slat);
  }

  // Back handle
  const handleMesh = new THREE.Mesh(new THREE.TorusGeometry(0.12, 0.025, 8, 16, Math.PI), metalMat);
  handleMesh.position.set(0, bodyH / 2 - 0.2, -bodyD / 2 - 1.1);
  handleMesh.rotation.set(Math.PI / 2, 0, 0);
  tvGroup.add(handleMesh);

  // Power cable
  const CableCurve = new THREE.CatmullRomCurve3([
    new THREE.Vector3(0.6, 0.2, -bodyD / 2 - 0.8),
    new THREE.Vector3(0.8, 0.0, -bodyD / 2 - 1.3),
    new THREE.Vector3(1.0, -0.3, -bodyD / 2 - 1.6),
    new THREE.Vector3(1.1, -0.7, -bodyD / 2 - 1.5),
  ]);
  tvGroup.add(new THREE.Mesh(
    new THREE.TubeGeometry(CableCurve, 20, 0.035, 8, false),
    new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.8 })
  ));

  // === UNIFIED FRONT FACE — mahogany panel with screen + controls ===
  const panelH = 2.3;
  const bezelW = 3.1, bezelH = 1.75;

  // Single front panel — spans the full front, mahogany
  const frontPanel = new THREE.Mesh(
    new RoundedBoxGeometry(3.5, panelH, 0.12, 6, 0.035),
    darkBodyMat
  );
  frontPanel.position.set(0, -0.05, bodyD / 2 + 0.01);
  frontPanel.castShadow = true;
  tvGroup.add(frontPanel);

  // Screen bezel frame — dark plastic, sits on front panel
  const screenBezel = new THREE.Mesh(
    new RoundedBoxGeometry(bezelW, bezelH, 0.07, 5, 0.02),
    darkPlasticMat
  );
  screenBezel.position.set(0, 0.25, bodyD / 2 + 0.065);
  tvGroup.add(screenBezel);

  // Chrome trim around screen
  const screenTrim = new THREE.Mesh(
    new RoundedBoxGeometry(bezelW + 0.04, bezelH + 0.04, 0.02, 5, 0.015),
    chromeMat
  );
  screenTrim.position.set(0, 0.25, bodyD / 2 + 0.1);
  tvGroup.add(screenTrim);

  // Screen — showreel video after TV powers on
  const showreelVideo = document.createElement('video');
  showreelVideo.src = '/showreel.mp4';
  showreelVideo.loop = true;
  showreelVideo.muted = true;
  showreelVideo.playsInline = true;
  showreelVideo.preload = 'auto';

  // Pre-buffer the video immediately so frames are ready by blink time
  showreelVideo.play().catch(() => {});

  
  const videoTex = new THREE.VideoTexture(showreelVideo);
  videoTex.minFilter = THREE.LinearFilter;
  videoTex.magFilter = THREE.LinearFilter;
  videoTex.generateMipmaps = false;

  // Screen material — map assigned from start, color black to hide video until blink-on.
  const screenMat = new THREE.MeshBasicMaterial({ map: videoTex, color: 0x000000 });
  const screenW = 2.85, screenH = 1.55;
  const screenMesh = new THREE.Mesh(new THREE.PlaneGeometry(screenW, screenH), screenMat);
  screenMesh.position.set(0, 0.25, bodyD / 2 + 0.5);
  tvGroup.add(screenMesh);


  // === CONTROLS ===
  const ctrlY = -0.78;
  const ctrlZ = bodyD / 2 + 0.07;

  // Control strip — darker inlay on the mahogany panel
  const ctrlStrip = new THREE.Mesh(
    new RoundedBoxGeometry(3.0, 0.5, 0.06, 4, 0.015),
    new THREE.MeshStandardMaterial({ map: makeGrungeTex(512, 128, 80, 55, 28, 88), roughness: 0.7, metalness: 0.0, color: 0x503820 })
  );
  ctrlStrip.position.set(0, ctrlY, ctrlZ - 0.01);
  tvGroup.add(ctrlStrip);

  // JAG brand label
  const labelCanvas = document.createElement('canvas');
  labelCanvas.width = 256; labelCanvas.height = 64;
  const lctx = labelCanvas.getContext('2d')!;
  lctx.fillStyle = '#4a2a18'; lctx.fillRect(0, 0, 256, 64);
  lctx.fillStyle = '#c4a878'; lctx.font = 'bold 28px sans-serif';
  lctx.textAlign = 'center'; lctx.textBaseline = 'middle';
  lctx.fillText('JAG', 128, 32);
  const labelMesh = new THREE.Mesh(
    new THREE.PlaneGeometry(0.4, 0.08),
    new THREE.MeshStandardMaterial({ map: new THREE.CanvasTexture(labelCanvas), roughness: 0.5, metalness: 0.1 })
  );
  labelMesh.position.set(0, ctrlY, ctrlZ + 0.04);
  tvGroup.add(labelMesh);

  // Simple knob — no handles, just a ridged cylinder + indicator dot
  function makeKnob(x: number): THREE.Group {
    const g = new THREE.Group();
    const body = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.08, 0.06, 24), trimMat);
    body.rotation.x = Math.PI / 2; g.add(body);
    const rim = new THREE.Mesh(new THREE.TorusGeometry(0.08, 0.012, 6, 20), chromeMat);
    rim.rotation.x = Math.PI / 2; rim.position.z = 0.015; g.add(rim);
    const dot = new THREE.Mesh(new THREE.SphereGeometry(0.012, 8, 8), chromeMat);
    dot.position.set(0, 0.035, 0); g.add(dot);
    g.position.set(x, ctrlY, ctrlZ + 0.04);
    return g;
  }
  tvGroup.add(makeKnob(-1.0));
  tvGroup.add(makeKnob(-0.6));

  // Channel dial — larger, with ridges
  const dialBody = new THREE.Mesh(new THREE.CylinderGeometry(0.13, 0.13, 0.06, 28), trimMat);
  dialBody.rotation.x = Math.PI / 2;
  const dialGroup = new THREE.Group();
  dialGroup.add(dialBody);
  // Ridges around dial edge
  for (let i = 0; i < 12; i++) {
    const ang = (i / 12) * Math.PI * 2;
    const ridge = new THREE.Mesh(new THREE.BoxGeometry(0.02, 0.01, 0.04), chromeMat);
    ridge.position.set(Math.sin(ang) * 0.13, Math.cos(ang) * 0.13, 0.02);
    dialGroup.add(ridge);
  }
  const dot = new THREE.Mesh(new THREE.SphereGeometry(0.014, 8, 8), chromeMat);
  dot.position.set(0.06, 0, 0.035); dialGroup.add(dot);
  dialGroup.position.set(1.3, ctrlY, ctrlZ + 0.04);
  tvGroup.add(dialGroup);

  // Power LED
  const ledMat = new THREE.MeshStandardMaterial({
    color: 0xff2200, emissive: 0xff2200, emissiveIntensity: 0, roughness: 0.3, metalness: 0.5,
  });
  const led = new THREE.Mesh(new THREE.SphereGeometry(0.025, 16, 16), ledMat);
  led.position.set(-1.4, ctrlY, ctrlZ + 0.04);
  tvGroup.add(led);

  // === ANTENNAS ===
  for (const xOff of [-0.35, 0.35]) {
    const base = new THREE.Mesh(new THREE.CylinderGeometry(0.06, 0.08, 0.12, 24), chromeMat);
    base.position.set(xOff, bodyH / 2 + 0.06, -0.2);
    tvGroup.add(base);
  }
  const antGeo = new THREE.CylinderGeometry(0.02, 0.012, 1.4, 16);
  const antennaL = new THREE.Mesh(antGeo, metalMat);
  antennaL.position.set(-0.35, bodyH / 2 + 0.76, -0.2);
  antennaL.rotation.z = 0.25;
  antennaL.castShadow = true;
  tvGroup.add(antennaL);
  const antennaR = new THREE.Mesh(antGeo, metalMat);
  antennaR.position.set(0.35, bodyH / 2 + 0.76, -0.2);
  antennaR.rotation.z = -0.25;
  antennaR.castShadow = true;
  tvGroup.add(antennaR);
  for (const xOff of [-0.35, 0.35]) {
    const tip = new THREE.Mesh(new THREE.SphereGeometry(0.035, 16, 16), chromeMat);
    tip.position.set(xOff, bodyH / 2 + 1.45, -0.2);
    tvGroup.add(tip);
  }

  // === LEGS — wooden pegs ===
  const legL = new THREE.Group();
  legL.position.set(-1.3, -bodyH / 2 - 0.2, 0);
  legL.rotation.z = 0.08;
  legL.add(new THREE.Mesh(new THREE.CylinderGeometry(0.05, 0.03, 0.45, 12), woodMat));
  tvGroup.add(legL);

  const legR = new THREE.Group();
  legR.position.set(1.3, -bodyH / 2 - 0.2, 0);
  legR.rotation.z = -0.08;
  legR.add(new THREE.Mesh(new THREE.CylinderGeometry(0.05, 0.03, 0.45, 12), woodMat));
  tvGroup.add(legR);

  // --- DUST PARTICLES ---
  const dustCount = 300;
  const dustPositions = new Float32Array(dustCount * 3);
  const dustSizes = new Float32Array(dustCount);
  const dustSpeeds = new Float32Array(dustCount);
  for (let i = 0; i < dustCount; i++) {
    dustPositions[i * 3] = (Math.random() - 0.5) * 16;
    dustPositions[i * 3 + 1] = (Math.random() - 0.5) * 8 - 1;
    dustPositions[i * 3 + 2] = (Math.random() - 0.5) * 12 - 2;
    dustSizes[i] = 0.008 + Math.random() * 0.025;
    dustSpeeds[i] = 0.002 + Math.random() * 0.006;
  }
  const dustGeo = new THREE.BufferGeometry();
  dustGeo.setAttribute('position', new THREE.BufferAttribute(dustPositions, 3));
  const dustMat = new THREE.PointsMaterial({
    color: 0xaaaaaa,
    size: 0.02,
    transparent: true,
    opacity: 0.2,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
    sizeAttenuation: true,
  });
  const dustPoints = new THREE.Points(dustGeo, dustMat);
  scene.add(dustPoints);

  // TV starts above viewport — completely out of frame
  tvGroup.position.y = 10;
  const restY = 0.6;

  // --- POST-PROCESSING: BLOOM — subtle, moody glow ---
  const composer = new EffectComposer(renderer);
  const renderPass = new RenderPass(scene, camera);
  composer.addPass(renderPass);

  const bloomPass = new UnrealBloomPass(
    new THREE.Vector2(window.innerWidth, window.innerHeight),
    0.25,   // strength
    0.5,    // radius
    0.15    // threshold
  );
  composer.addPass(bloomPass);

  // --- Screen shake ---
  const shakeTarget = { x: 0, y: 0 };
  let shaking = false;
  function screenShake(intensity: number, duration: number) {
    if (shaking) return;
    shaking = true;
    const start = performance.now();
    function tick() {
      const elapsed = performance.now() - start;
      if (elapsed > duration) { shakeTarget.x = 0; shakeTarget.y = 0; shaking = false; return; }
      const t = 1 - elapsed / duration;
      const str = intensity * t * t;
      shakeTarget.x = (Math.random() - 0.5) * 2 * str;
      shakeTarget.y = (Math.random() - 0.5) * 2 * str;
      requestAnimationFrame(tick);
    }
    tick();
  }

  function pageShake(amount: number, duration: number) {
    const el = document.getElementById('hero')!;
    const start = performance.now();
    function tick() {
      const elapsed = performance.now() - start;
      if (elapsed > duration) { gsap.set(el, { x: 0, y: 0 }); return; }
      const t = 1 - elapsed / duration;
      const str = amount * t * t;
      gsap.set(el, {
        x: (Math.random() - 0.5) * 2 * str,
        y: (Math.random() - 0.5) * 2 * str * 0.6,
      });
      requestAnimationFrame(tick);
    }
    tick();
  }

  // --- Animation ---
  const tl = gsap.timeline({ delay: 0.6 });

  // Drop — accelerating slam to rest position
  tl.to(tvGroup.position, { y: restY, duration: 2.0, ease: 'power4.in' })
  // Impact — left peg snaps, TV tilts
  .call(() => { screenShake(0.03, 700); pageShake(4, 350); })
  // Left peg crushes flat
  .to(legL.scale, { y: 0.02, x: 1.5, z: 1.5, duration: 0.08, ease: 'expo.out',
    onComplete: () => { legL.visible = false; }
  }, '<')
  // TV tilts right
  .to(tvGroup.rotation, { z: -0.08, duration: 0.2, ease: 'power2.in' }, '<')
  .to(tvGroup.position, { y: restY - 0.08, duration: 0.2, ease: 'power2.in' }, '<')
  // Right peg gives way
  .call(() => { screenShake(0.015, 400); pageShake(2, 200); }, null, '+=0.05')
  .to(legR.scale, { y: 0.02, x: 1.5, z: 1.5, duration: 0.08, ease: 'expo.out',
    onComplete: () => { legR.visible = false; }
  }, '<')
  // TV levels out
  .to(tvGroup.rotation, { z: 0, duration: 0.3, ease: 'power3.inOut' }, '<')
  .to(tvGroup.position, { y: restY - 0.15, duration: 0.3, ease: 'power3.inOut' }, '<')
  // Tiny damped wobble
  .to(tvGroup.rotation, { z: 0.005, duration: 0.12, ease: 'sine.out' }, '-=0.08')
  .to(tvGroup.rotation, { z: -0.002, duration: 0.15, ease: 'sine.inOut' })
  .to(tvGroup.rotation, { z: 0, duration: 0.1, ease: 'sine.out' })
  // Power LED on
  .to(ledMat, { emissiveIntensity: 2.5, duration: 0.08, ease: 'sine.out' }, '-=0.12')
  // Camera pushes in
  .addLabel('camPush')
  .to(camera.position, { z: 7.5, x: 0.15, y: 1.0, duration: 3.0, ease: 'power3.inOut' }, 'camPush')
  // CRT blink on like an old light — warm flicker then steady
  .call(() => {
    showreelVideo.play().catch(() => {});
    // Ensure color starts black (should already be)
    screenMat.color.set(0x000000);
  }, null, 'camPush+=0.5')
  .to(screenMat.color, { r: 0.2, g: 0.2, b: 0.2, duration: 0.04 })
  .to(screenMat.color, { r: 0.9, g: 0.9, b: 0.9, duration: 0.04 })
  .to(screenMat.color, { r: 0.3, g: 0.3, b: 0.3, duration: 0.03 })
  .to(screenMat.color, { r: 1, g: 1, b: 1, duration: 0.25, ease: 'power2.out' });

  // Fixed lookAt target — never tilts to follow the TV
  const lookTarget = new THREE.Vector3(0, 0.3, 0);

  // --- Render loop ---
  let rafId: number;
  function render() {
    rafId = requestAnimationFrame(render);

    // Apply shake
    camera.position.x += shakeTarget.x;
    camera.position.y += shakeTarget.y;

    // Camera stays locked ahead — TV drops into frame naturally
    camera.lookAt(lookTarget);

    // Animate dust — slow drift
    const dustPos = dustPoints.geometry.attributes.position.array as Float32Array;
    for (let i = 0; i < dustCount; i++) {
      dustPos[i * 3 + 1] += dustSpeeds[i];
      dustPos[i * 3] += Math.sin(performance.now() * 0.0003 + i) * 0.0002;
      if (dustPos[i * 3 + 1] > 4) dustPos[i * 3 + 1] = -4;
    }
    dustPoints.geometry.attributes.position.needsUpdate = true;

    // Ensure the video texture pushes new frames to the GPU
    if (videoTex) videoTex.needsUpdate = true;



    composer.render();

    // Undo shake
    camera.position.x -= shakeTarget.x;
    camera.position.y -= shakeTarget.y;
  }
  render();

  const onResize = () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
    composer.setSize(window.innerWidth, window.innerHeight);
  };
  window.addEventListener('resize', onResize);

  document.addEventListener('astro:before-swap', () => {
    cancelAnimationFrame(rafId);
    window.removeEventListener('resize', onResize);
    showreelVideo.pause();
    showreelVideo.src = '';
    renderer.dispose();
  });
}

document.addEventListener('astro:page-load', initHero, { once: true });
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initHero, { once: true });
} else {
  initHero();
}
</script>