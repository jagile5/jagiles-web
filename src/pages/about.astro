---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  'DJI',
  'Premiere Pro',
  'DaVinci Resolve',
  'Drone Gear',
];

const interests = ['FPV Drones', 'OneWheel', 'Homelab', 'Photography'];
---

<BaseLayout title="About — Joshua Giles">
  <section class="relative min-h-screen py-32 md:py-36">
    <div class="grain-overlay" />
    <div class="relative z-10 max-w-6xl mx-auto px-6" data-animate>
      <!-- Heading -->
      <p class="eyebrow">About</p>
      <h1 class="section-heading mb-12">Joshua Giles</h1>

      <!-- Two-column layout: text + placeholder image -->
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
        <!-- Text column -->
        <div class="space-y-6 body-text text-lg">
          <p>
            Videographer and drone operator based in North Vancouver, BC, originally from
            New Zealand. Got into video work through a mix of curiosity and stubbornness,
            and now splits his time between client shoots and personal projects.
          </p>
          <p>
            When I'm not behind a camera I'm flying FPV drones, riding a OneWheel I built
            myself, or tinkering with whatever homelab project is currently half-finished.
          </p>
        </div>

        <!-- Placeholder image column -->
        <div class="aspect-[3/4] w-full max-w-sm mx-auto rounded-2xl border border-white/10
                    bg-surface flex items-center justify-center">
          <span class="text-text/30 font-display text-sm tracking-widest uppercase">Photo</span>
        </div>
      </div>

      <!-- Tools I use — channel preset buttons -->
      <div class="mt-20">
        <p class="eyebrow mb-5">Tools I use</p>
        <div class="flex flex-wrap gap-3">
          {tools.map((tool) => (
            <span class="channel-preset">{tool}</span>
          ))}
        </div>
      </div>

      <!-- Interest pills -->
      <div class="mt-12">
        <p class="eyebrow mb-5">Also into</p>
        <div class="flex flex-wrap gap-3">
          {interests.map((interest) => (
            <span class="interest-pill">{interest}</span>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-16">
        <a href="/contact" class="btn-primary">Get in Touch</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .channel-preset {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border: 1px solid rgba(45, 138, 233, 0.3);
    border-radius: 0.5rem;
    background: rgba(45, 138, 233, 0.08);
    color: var(--color-primary);
    font-family: 'Syne', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: all 0.3s ease;
    cursor: default;
  }

  .channel-preset:hover {
    background: rgba(45, 138, 233, 0.18);
    border-color: rgba(45, 138, 233, 0.6);
    box-shadow: 0 0 12px rgba(45, 138, 233, 0.15);
  }

  .interest-pill {
    display: inline-block;
    padding: 0.4rem 1.1rem;
    border: 1px solid rgba(240, 237, 232, 0.15);
    border-radius: 999px;
    background: rgba(240, 237, 232, 0.04);
    color: var(--color-text);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    transition: all 0.3s ease;
    cursor: default;
  }

  .interest-pill:hover {
    background: rgba(240, 237, 232, 0.1);
    border-color: rgba(240, 237, 232, 0.3);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('astro:page-load', () => {
    gsap.from('[data-animate]', {
      scrollTrigger: {
        trigger: '[data-animate]',
        start: 'top 80%',
      },
      opacity: 0,
      y: 40,
      duration: 0.8,
      ease: 'power3.out',
    });
  });
</script>